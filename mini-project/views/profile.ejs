<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title>Document</title>
</head>
<body>
    <div class="h-full w-full text-white bg-zinc-900 p-10">
       <div class="w-full flex justify-end">
             <a class="bg-red-500 rounded-md px-3 py-2 text-sm mb-5 inline-block" href="/logout">Logout</a>
       </div>
        <h3 class="text-3xl mb-5"> Holla, <%= user.name %>  👋🏻</h3>
        <h5 class="mb-5">You can create a new Post.</h5>
        <form method="post" action="/posts">
            <textarea class="p-3 outline-none resize-none w-1/3 bg-transparent border-2 border-zinc-800 rounded-md " name="content" id="" placeholder="What's on Your Mind?"></textarea>
            <input class=" w-40 px-3 py-2 bg-blue-500 block rounded-md mt-2 text-sm" type="submit" value="Create new Post">
        </form>

        <div class="posts mt-20">
            <h3 class="text-zinc-400">Your Posts..</h3>
            <div class="postcontainer mt-5">
                <% user.posts.reverse   ().forEach(function(post){ %>
                    <div class="post w-1/3 p-4 mb-5 rounded-md border-[1px] bg-zinc-800 border-zinc-700">
                    <h2 class="text-blue-500 mb-2"><%= user.username %></h2>
                    <p class="text-sm tracking-tight"><%= post.content %></p>
                    <div class="btn flex gap-4 mt-5">
                        <a class="text-blue-500" href="/like/<%= post._id %>">Like</a>
                        <a class="text-zinc-600" href="">edit</a>
                    </div>
                </div>
               <% }); %>
            </div>
        </div>
    </div>
    
</body>
</html>