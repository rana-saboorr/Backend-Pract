<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>
    <div class="main-full min-h-screen bg-zinc-900">
        <div class="form p-10 text-white">
            <form action="/create" method="post">
                <input class="block px-5 py-2 bg-zinc-800 w-full rounded-md" type="text" placeholder="Title goes here"
                    name="title">
                <textarea class="block px-5 py-2 bg-zinc-800 resize-nonen mt-2 w-full rounded-md" name="details" id=""
                    placeholder="Write your task here"></textarea>
                <input class="mt-2 bg-blue-600 px-5 py-2" type="submit" value="Create Task">
            </form>
        </div>
        <div class="task flex gap-3 flex-wrap p-10 ">
            <% if(files.length> 0){ %>
                <% files.forEach(function(val){%>
                    <div class="task min-w-72 px-3 rounde-md py-4 bg-zinc-800">
                        <h1 class="text-white text-3xl tracking-tighter">
                            <%= val %>
                        </h1>
                       <div class="flex w-full justify-between items-center mt-3">
                         <a class="text-blue-500 inline-block" href="/file/<%= val%>">
                            Read More
                        </a>    
                        <a class="text-zinc-600" href="/edit/<%= val %>">edit filename</a>
                       </div>
                    </div>
                    <% }) %>
            <% } else { %>
                            <h3 class="text-zinc-600">No tasks yet.</h3>
                            <% } %>


        </div>
    </div>
</body>

</html>